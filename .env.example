SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Absolute path to your Obsidian vault folder
OBSIDIAN_VAULT_PATH=/Users/you/path/to/your/vault

# LM Studio (defaults shown)
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Optional: exact model name shown in LM Studio (any value works if only one model is loaded)
# LM_STUDIO_MODEL=local-model

# Optional: override the assistant's system prompt
# SYSTEM_PROMPT=You are a helpful assistant for the standardpixel team with access to our Obsidian vault.
